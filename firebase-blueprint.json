{
  "entities": {
    "Feedback": {
      "title": "User Feedback",
      "description": "Suggestions and bug reports from users",
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "The feedback message content"
        },
        "type": {
          "type": "string",
          "enum": ["Suggestion", "Bug", "Improvement"],
          "description": "The category of feedback"
        },
        "rating": {
          "type": "integer",
          "description": "Star rating from 1 to 5"
        },
        "name": {
          "type": "string",
          "description": "The name of the user (optional)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the feedback was submitted"
        }
      },
      "required": ["message", "type", "createdAt"]
    }
  },
  "firestore": {
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of all user feedback"
    }
  }
}
