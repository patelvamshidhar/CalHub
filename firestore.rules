rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: feedback
    // Document ID: auto-generated
    // Fields:
    //   - message: string (required, 1-1000 chars)
    //   - type: string (required, ['Suggestion', 'Bug'])
    //   - userId: string (required, matches auth.uid)
    //   - userEmail: string (required, matches auth.token.email)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "reddyvamshi607@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['message', 'type', 'createdAt']) &&
             data.keys().hasOnly(['message', 'type', 'name', 'email', 'createdAt']) &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 1000 &&
             data.type in ['Suggestion', 'Bug'] &&
             (data.name == null || (data.name is string && data.name.size() <= 100)) &&
             (data.email == null || (data.email is string && data.email.size() <= 100)) &&
             data.createdAt is timestamp;
    }

    match /feedback/{feedbackId} {
      // Only admin can read all feedback
      allow read: if isAdmin();
      
      // Anyone can submit feedback
      allow create: if isValidFeedback(request.resource.data);
      
      // Only admin can update or delete
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
