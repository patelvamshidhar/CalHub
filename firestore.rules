rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: feedback
    // Document ID: auto-generated
    // Fields:
    //   - message: string (required, 1-1000 chars)
    //   - type: string (required, ['Suggestion', 'Bug'])
    //   - userId: string (required, matches auth.uid)
    //   - userEmail: string (required, matches auth.token.email)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "reddyvamshi607@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['message', 'type', 'createdAt']) &&
             data.keys().hasOnly(['message', 'type', 'name', 'rating', 'createdAt']) &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 1000 &&
             data.type in ['Suggestion', 'Bug', 'Improvement'] &&
             (data.name == null || (data.name is string && data.name.size() <= 100)) &&
             (data.rating == null || (data.rating is int && data.rating >= 0 && data.rating <= 5)) &&
             data.createdAt is timestamp;
    }

    match /feedback/{feedbackId} {
      // Admin dashboard now uses a local password, so we allow read access.
      // INSECURE: In a production app, use Firebase Auth for admin access.
      allow read: if true;
      
      // Anyone can submit feedback
      allow create: if isValidFeedback(request.resource.data);
      
      // Only allow updates/deletes if needed (currently not used by admin UI)
      allow update, delete: if true;
    }

    match /stats/{docId} {
      allow read: if true;
      allow create, update: if true;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
